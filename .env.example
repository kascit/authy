# Server
PORT=3000
NODE_ENV=development
AUTH_BASE_URL=http://localhost:3000

# Turso Database
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Auth
TOTP_SECRET=           # Leave empty on first run, /api/setup will generate one
SESSION_SECRET=your-random-session-secret-here
ADMIN_DURATION_HOURS=24

# Cookie
COOKIE_DOMAIN=.dhanur.me

# CORS — comma-separated origins
ALLOWED_ORIGINS=https://dhanur.me,https://auth.dhanur.me,https://tasks.dhanur.me,https://linkr.dhanur.me

# OAuth Providers — only configure the ones you want to enable
# Providers without credentials will be automatically hidden

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=




TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Apple Sign-In (requires more setup)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
